FROM node:20-alpine AS builder

WORKDIR /app

ARG VITE_FILEBROWSER_PC_DOMAIN
ARG VITE_TORRENT_PC_DOMAIN
ARG VITE_FILEBROWSER_RPI_DOMAIN
ARG VITE_TORRENT_RPI_DOMAIN
ARG VITE_FILEBROWSER_VPS_DOMAIN
ARG VITE_PORTAINER_DOMAIN
ARG VITE_GUACAMOLE_DOMAIN
ARG VITE_COMFYUI_DOMAIN
ARG VITE_ACESTEP_DOMAIN
ARG VITE_OPENWEBUI_DOMAIN
ARG VITE_OPENCLAW_DOMAIN
ARG VITE_OPENCLAW_TOKEN

ENV VITE_FILEBROWSER_PC_DOMAIN=$VITE_FILEBROWSER_PC_DOMAIN
ENV VITE_TORRENT_PC_DOMAIN=$VITE_TORRENT_PC_DOMAIN
ENV VITE_FILEBROWSER_RPI_DOMAIN=$VITE_FILEBROWSER_RPI_DOMAIN
ENV VITE_TORRENT_RPI_DOMAIN=$VITE_TORRENT_RPI_DOMAIN
ENV VITE_FILEBROWSER_VPS_DOMAIN=$VITE_FILEBROWSER_VPS_DOMAIN
ENV VITE_PORTAINER_DOMAIN=$VITE_PORTAINER_DOMAIN
ENV VITE_GUACAMOLE_DOMAIN=$VITE_GUACAMOLE_DOMAIN
ENV VITE_COMFYUI_DOMAIN=$VITE_COMFYUI_DOMAIN
ENV VITE_ACESTEP_DOMAIN=$VITE_ACESTEP_DOMAIN
ENV VITE_OPENWEBUI_DOMAIN=$VITE_OPENWEBUI_DOMAIN
ENV VITE_OPENCLAW_DOMAIN=$VITE_OPENCLAW_DOMAIN
ENV VITE_OPENCLAW_TOKEN=$VITE_OPENCLAW_TOKEN

COPY package.json .
RUN npm install
COPY . .
RUN npm run build

FROM nginx:alpine
COPY --from=builder /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf

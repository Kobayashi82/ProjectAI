FROM node:20-alpine AS builder

WORKDIR /app

ARG VITE_PORTAINER_DOMAIN
ARG VITE_UPTIME_KUMA_DOMAIN
ARG VITE_GUACAMOLE_DOMAIN
ARG VITE_FILEBROWSER_VPS_DOMAIN
ARG VITE_SEARXNG_DOMAIN
ARG VITE_NAVIDROME_DOMAIN
ARG VITE_KAVITA_DOMAIN
ARG VITE_ROMM_DOMAIN
ARG VITE_FILEBROWSER_RPI_DOMAIN
ARG VITE_TORRENT_RPI_DOMAIN
ARG VITE_FILEBROWSER_PC_DOMAIN
ARG VITE_NAVIDROME_PC_DOMAIN
ARG VITE_JELLYFIN_PC_DOMAIN
ARG VITE_TORRENT_PC_DOMAIN
ARG VITE_SUNSHINE_PC_DOMAIN
ARG VITE_MOONLIGHT_PC_DOMAIN
ARG VITE_ACESTEP_DOMAIN
ARG VITE_COMFYUI_DOMAIN
ARG VITE_OPENWEBUI_DOMAIN

ENV VITE_PORTAINER_DOMAIN=$VITE_PORTAINER_DOMAIN
ENV VITE_UPTIME_KUMA_DOMAIN=$VITE_UPTIME_KUMA_DOMAIN
ENV VITE_GUACAMOLE_DOMAIN=$VITE_GUACAMOLE_DOMAIN
ENV VITE_FILEBROWSER_VPS_DOMAIN=$VITE_FILEBROWSER_VPS_DOMAIN
ENV VITE_SEARXNG_DOMAIN=$VITE_SEARXNG_DOMAIN
ENV VITE_NAVIDROME_DOMAIN=$VITE_NAVIDROME_DOMAIN
ENV VITE_KAVITA_DOMAIN=$VITE_KAVITA_DOMAIN
ENV VITE_ROMM_DOMAIN=$VITE_ROMM_DOMAIN
ENV VITE_FILEBROWSER_RPI_DOMAIN=$VITE_FILEBROWSER_RPI_DOMAIN
ENV VITE_TORRENT_RPI_DOMAIN=$VITE_TORRENT_RPI_DOMAIN
ENV VITE_FILEBROWSER_PC_DOMAIN=$VITE_FILEBROWSER_PC_DOMAIN
ENV VITE_NAVIDROME_PC_DOMAIN=$VITE_NAVIDROME_PC_DOMAIN
ENV VITE_JELLYFIN_PC_DOMAIN=$VITE_JELLYFIN_PC_DOMAIN
ENV VITE_TORRENT_PC_DOMAIN=$VITE_TORRENT_PC_DOMAIN
ENV VITE_SUNSHINE_PC_DOMAIN=$VITE_SUNSHINE_PC_DOMAIN
ENV VITE_MOONLIGHT_PC_DOMAIN=$VITE_MOONLIGHT_PC_DOMAIN
ENV VITE_ACESTEP_DOMAIN=$VITE_ACESTEP_DOMAIN
ENV VITE_COMFYUI_DOMAIN=$VITE_COMFYUI_DOMAIN
ENV VITE_OPENWEBUI_DOMAIN=$VITE_OPENWEBUI_DOMAIN

COPY package.json .
RUN npm install
COPY . .
RUN npm run build

FROM nginx:alpine
COPY --from=builder /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
